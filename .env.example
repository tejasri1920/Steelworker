# .env.example
#
# Copy this file to ".env" and fill in your real values.
# The real ".env" is in .gitignore and will never be committed.
#
# How to copy:
#   Windows cmd:   copy .env.example .env
#   PowerShell:    Copy-Item .env.example .env
#   Mac/Linux:     cp .env.example .env

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# These are used by the PostgreSQL Docker container on first startup
# to create the database, user, and password.
POSTGRES_USER=steelworks
POSTGRES_PASSWORD=changeme
POSTGRES_DB=steelworks_ops

# Exposed port on your local machine (5432 is the PostgreSQL default).
# Change to e.g. 5433 if you already have a local Postgres running on 5432.
POSTGRES_PORT=5432

# ── Backend ───────────────────────────────────────────────────────────────────
# Full connection string used by SQLAlchemy inside the backend container.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# "db" is the Docker Compose service name — Docker resolves it to the container IP.
DATABASE_URL=postgresql://steelworks:changeme@db:5432/steelworks_ops

# Port the FastAPI server listens on (inside Docker and exposed to your host).
BACKEND_PORT=8000

# CORS: which browser origins are allowed to call the API.
# In development, the React dev server runs on port 5173.
# Separate multiple origins with a comma (no spaces).
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
# The URL the React app uses to reach the backend API.
# In Docker, Nginx proxies /api/* to the backend, so this can be empty ("").
# When running the React dev server locally (npm run dev), set to:
#   VITE_API_BASE_URL=http://localhost:8000
VITE_API_BASE_URL=

# Port the Nginx container serves the React app on.
FRONTEND_PORT=3000
