# .gitignore
#
# Tells Git which files to ignore (never commit).
# Rule of thumb: ignore secrets, generated outputs, and local machine artifacts.
#
# NOTE: gitignore does NOT support inline comments after patterns.
# Each pattern must be on its own line with no trailing # comments.

# ── Secrets ──────────────────────────────────────────────────────────────────
# .env holds your real DB password, API keys, etc. — NEVER commit it.
# .env.example (committed) is the safe template with placeholder values.
.env
*.env

# ── Python ───────────────────────────────────────────────────────────────────
# Compiled bytecode — regenerated automatically by Python
__pycache__/
*.py[cod]
*.pyo
# Poetry virtual environment — machine-specific, not portable
.venv/
# Package metadata generated by build tools
*.egg-info/
# Built packages
dist/
# Pytest cache and coverage artifacts
.pytest_cache/
.coverage
htmlcov/

# ── Node / Frontend build ────────────────────────────────────────────────────
# npm dependencies — reinstalled with `npm install`
node_modules/
# Vite production build output
frontend/dist/

# ── OS artifacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
