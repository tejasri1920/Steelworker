{
  "name": "steelworks-ops-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Operations Analytics frontend — React 18 + Vite + TypeScript + Tailwind CSS",
  "scripts": {
    "dev":     "vite",
    "build":   "tsc && vite build",
    "preview": "vite preview",
    "test":    "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "react":           "^18.3.1",
    "react-dom":       "^18.3.1",
    "react-router-dom": "^6.24.0",
    "@tanstack/react-query": "^5.49.0",
    "axios":           "^1.7.2"
  },
  "devDependencies": {
    "@types/react":          "^18.3.3",
    "@types/react-dom":      "^18.3.0",
    "@vitejs/plugin-react":  "^4.3.1",
    "typescript":            "^5.5.3",
    "vite":                  "^5.3.4",
    "tailwindcss":           "^3.4.7",
    "postcss":               "^8.4.40",
    "autoprefixer":          "^10.4.19",
    "vitest":                "^1.6.0",
    "@vitest/coverage-v8":   "^1.6.0",
    "@testing-library/react":      "^16.0.0",
    "@testing-library/jest-dom":   "^6.4.6",
    "@testing-library/user-event": "^14.5.2",
    "jsdom":                 "^24.1.1"
  }
}
